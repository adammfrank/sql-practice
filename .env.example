# Use 127.0.0.1 rather than localhost: on some systems (notably Windows and
# Docker Desktop) "localhost" resolves to the IPv6 address ::1 first, and
# Postgres connections can hang for ~2 minutes before falling back to IPv4.
# 127.0.0.1 forces IPv4 and avoids that delay.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=dojo
POSTGRES_PASSWORD=dojo
POSTGRES_MAINTENANCE_DB=postgres
DOJO_TEMPLATE_DB=dojo_template
